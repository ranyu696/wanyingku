{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install --frozen-lockfile && cd admin && bun run build"
  },
  "deploy": {
    "startCommand": "/bin/sh -c \"cd admin && bunx serve -s dist -l ${PORT:-8080}\"",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
