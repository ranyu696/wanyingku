# 影视聚合后端配置示例。复制为 config.yaml 后按需修改。
app:
  name: yinshi
  env: dev               # dev | prod
  addr: ":8080"
  api_prefix: "/api/v1"
  timezone: "Asia/Shanghai"
  jwt_secret: "change-me-to-a-long-random-string"
  jwt_expire_hours: 168  # 7 天

database:
  # Homebrew Postgres 默认用当前系统用户、无密码、peer/trust 本地连接
  dsn: "host=localhost user=xiaoxin dbname=yinshi port=5432 sslmode=disable TimeZone=Asia/Shanghai"
  max_open: 50
  max_idle: 10
  log_sql: false

redis:
  addr: "localhost:6379"
  password: ""
  db: 0
  cache_ttl_sec: 600     # 列表/详情默认缓存时长

meilisearch:
  enabled: true
  host: "http://localhost:7700"
  api_key: ""            # 本地 dev 可留空；生产务必设置 master key
  index: "titles"

tmdb:
  enabled: true          # 归类引擎的权威库（聚类主键来源）
  api_key: ""            # 在 https://www.themoviedb.org/settings/api 申请
  base_url: "https://api.themoviedb.org/3"
  image_base: "https://image.tmdb.org/t/p"
  language: "zh-CN"
  region: "CN"
  proxy: ""              # 如需代理访问 TMDB，填 http://127.0.0.1:7890

ai:
  # 向量层：需要 pgvector(002_vector.sql) + 一个嵌入模型。未启用时归类自动降级到 pg_trgm 模糊匹配。
  vector_enabled: false
  # LLM 仲裁：灰区相似度交给大模型判定是否同一部。未启用时按阈值规则判定。
  llm_enabled: false
  provider: "openai"     # OpenAI 兼容协议，可指向 OpenAI / 本地 Ollama / 任意兼容端点
  base_url: "https://api.openai.com/v1"
  api_key: ""
  embedding_model: "text-embedding-3-small"
  embedding_dim: 1536    # 改模型记得同步改 002_vector.sql 里的向量维度
  chat_model: "gpt-4o-mini"
  request_timeout_sec: 30

resolve:
  fuzzy_threshold: 0.42      # pg_trgm 相似度召回候选阈值
  auto_merge_threshold: 0.86 # >= 该分数直接合并，不再问 LLM
  llm_review_low: 0.62       # [llm_review_low, auto_merge) 区间且 llm 开启时交给 LLM
  year_tolerance: 1          # 年份允许偏差
  enable_tmdb: true

collect:
  concurrency: 3             # 同时采集的源数
  request_timeout_sec: 20
  user_agent: "Mozilla/5.0 (yinshi-collector)"
  default_interval_min: 720  # 源默认采集间隔（增量）
  scheduler_enabled: true    # server 内置定时采集；也可单独跑 cmd/worker
  page_delay_ms: 1500        # 翻页请求间隔毫秒（限速，避免被采集站封禁）
  max_pages: 0               # 单源单次最大页数，0=默认上限(2000)

storage:
  # 图床（S3 兼容）。把 TMDB/采集源海报转存到自有桶，并计算 BlurHash 占位。
  # 支持 CoreIX/S4、阿里云 OSS、腾讯 COS、Cloudflare R2、AWS S3、MinIO 等。
  enabled: false
  endpoint: ""               # 不含协议，如 s3.amazonaws.com / oss-cn-hangzhou.aliyuncs.com
  region: ""
  bucket: ""
  access_key: ""
  secret_key: ""
  use_ssl: true
  public_base_url: ""        # 公开访问/CDN 前缀，如 https://img.example.com
  prefix: "images"           # 对象 key 前缀
